{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Lumira Docs",
  "colors": {
    "primary": "#f9a8d4",
    "light": "#c4b5fd",
    "dark": "#f9a8d4"
  },
  "favicon": "/images/favicon-32x32.png",
  "logo": {
    "light": "/images/LumiraRankingNoBG.png",
    "dark": "/images/LumiraRankingNoBG.png"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#08050d",
      "light": "#f8f5ff"
    },
    "decoration": "grid"
  },
  "navbar": {
    "links": [
      {
        "label": "Portal",
        "href": "https://canary-portal.lumiraranking.co.uk/login"
      },
      {
        "label": "Support",
        "href": "/support/support-pin"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Lumira",
      "href": "https://canary-portal.lumiraranking.co.uk/login"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://lumiraranking.co.uk",
          "icon": "globe",
          "color": {
            "light": "#f9a8d4",
            "dark": "#f9a8d4"
          }
        },
        {
          "anchor": "Portal",
          "href": "https://canary-portal.lumiraranking.co.uk/login",
          "icon": "grid-2",
          "color": {
            "light": "#c4b5fd",
            "dark": "#c4b5fd"
          }
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/lumiraranking",
          "icon": "message-circle",
          "color": {
            "light": "#6ee7b7",
            "dark": "#6ee7b7"
          }
        }
      ]
    },
    "tabs": [
      {
        "tab": "Start",
        "icon": "sparkles",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "start/quickstart",
              "start/concepts",
              "start/plans"
            ]
          },
          {
            "group": "Workspace setup",
            "pages": [
              "setup/create-workspace",
              "setup/connect-discord",
              "setup/connect-roblox",
              "setup/support-pin"
            ]
          }
        ]
      },
      {
        "tab": "Workspace",
        "icon": "grid-2",
        "groups": [
          {
            "group": "Core operations",
            "pages": [
              "workspace/verification",
              "workspace/verified-users",
              "workspace/role-binds",
              "workspace/ranking",
              "workspace/sessions"
            ]
          },
          {
            "group": "Pro operations",
            "pages": [
              "workspace/loa",
              "workspace/modmail",
              "workspace/embeds",
              "workspace/forms",
              "workspace/trust-network"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "icon": "rectangle-terminal",
        "groups": [
          {
            "group": "API access",
            "pages": [
              "api/introduction",
              "api/authentication",
              "api/ranking-actions",
              "api/rate-limits",
              "api/errors"
            ]
          },
          {
            "group": "Roblox plugin",
            "pages": [
              "plugins/basic-admin",
              "plugins/promote",
              "plugins/demote",
              "plugins/set-rank"
            ]
          }
        ]
      },
      {
        "tab": "Policies",
        "icon": "shield-check",
        "groups": [
          {
            "group": "Support and safety",
            "pages": [
              "support/support-pin",
              "policies/community-rules",
              "policies/trust-and-untrusted"
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/trustfundi",
      "x": "https://x.com/LumiraRanking"
    },
    "links": [
      {
        "label": "Terms",
        "href": "https://lumiraranking.co.uk/terms"
      },
      {
        "label": "Privacy",
        "href": "https://lumiraranking.co.uk/privacy"
      },
      {
        "label": "Support",
        "href": "/support/support-pin"
      }
    ]
  }
}

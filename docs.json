        }
      ]
    },
    "tabs": [
      {
        "tab": "Home",
        "icon": "house-chimney-window",
        "pages": [
          {
            "group": "Overview",
            "pages": [
              "welcome-to-lumira",
              "rules-and-regulation"
            ]
          },
          {
            "group": "Label & Partners",
            "icon": "handshake-simple",
            "pages": [
              "become-a-label",
              "benefits"
            ]
          },
          {
            "group": "Plans",
            "icon": "credit-card",
            "pages": [
              "core",
              "plus",
              "ultimate"
            ]
          },
          {
            "group": "Careers",
            "icon": "suitcase",
            "pages": [
              "public-relations-team"
            ]
          }
        ]
      },
      {
        "tab": "Portal",
        "icon": "book-blank",
        "pages": [
          {
            "group": "Getting Started",
            "icon": "star",
            "pages": [
              "initial-setup"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "icon": "rectangle-terminal",
        "groups": [
          {
            "group": "Overview",
            "icon": "terminal",
            "pages": [
              "introduction"
            ]
          },
          {
            "group": "Basic Admin Integration",
            "icon": "clipboard-check",
            "pages": [
              "promote-plugin",
              "demote-plugin"
            ]
          }
        ]
      }
    ]
  },
  "logo": "<span style=\"background: linear-gradient(135deg,#F6B5C5,#C9B6E4,#9ED1E7,#8FD6CF); -webkit-background-clip: text; color: transparent; font-weight: bold;\">Lumira Ranking</span>",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }

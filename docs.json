    "primary": {
      "type": "button",
      "label": "Main Page",
      "href": "https://lumiraranking.co.uk"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
